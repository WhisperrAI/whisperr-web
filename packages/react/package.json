{
  "name": "@whisperr/react",
  "version": "0.1.2",
  "description": "React bindings for the Whisperr web SDK — provider + hooks.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": { "react": ">=17" },
  "dependencies": { "@whisperr/web": "^0.1.0" },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "tsup": "^8.2.4",
    "typescript": "^5.6.2"
  }
}
