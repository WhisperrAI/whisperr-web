{
  "name": "@whisperr/web",
  "version": "0.1.5",
  "description": "Whisperr web SDK \u2014 tiny, reliable churn-signal event tracking for any JavaScript app.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "size": "node scripts/size-check.mjs"
  },
  "devDependencies": {
    "jsdom": "^25.0.0",
    "tsup": "^8.2.4",
    "typescript": "^5.6.2",
    "vitest": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WhisperrAI/whisperr-web.git",
    "directory": "packages/web"
  },
  "homepage": "https://github.com/WhisperrAI/whisperr-web#readme"
}
